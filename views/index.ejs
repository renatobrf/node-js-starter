<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ObsConsulta | Architecture & Observability</title>
  <style>
    :root {
      --bg: #07111d;
      --bg-soft: #0f1f2e;
      --surface: rgba(255, 255, 255, 0.06);
      --surface-strong: #ffffff;
      --text: #e6f1ff;
      --text-muted: #8fa3bd;
      --primary: #3ec5ff;
      --primary-strong: #1f8cff;
      --accent: #5fd4ff;
      --border: rgba(255, 255, 255, 0.12);
      --success: #20c997;
      --shadow: 0 20px 45px rgba(0, 0, 0, 0.25);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: Inter, "Segoe UI", Roboto, Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(62, 197, 255, 0.15), transparent 28%),
        linear-gradient(135deg, var(--bg) 0%, #091827 100%);
      color: var(--text);
      line-height: 1.6;
    }

    a { color: inherit; text-decoration: none; }
    .container { width: min(1180px, calc(100% - 2rem)); margin: 0 auto; }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(16px);
      background: rgba(7, 17, 29, 0.72);
      border-bottom: 1px solid var(--border);
    }

    .header-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
    }

    .brand {
      font-size: 1.2rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .brand span { color: var(--primary); }

    .nav-links { display: flex; gap: 1.25rem; color: var(--text-muted); }
    .nav-links a:hover { color: var(--primary); }

    .hero {
      padding: 5.5rem 0 4rem;
      position: relative;
      overflow: hidden;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 2rem;
      align-items: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.7rem;
      border-radius: 999px;
      background: rgba(62, 197, 255, 0.14);
      color: var(--accent);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    .hero h1 {
      font-size: clamp(2.2rem, 4vw, 3.6rem);
      line-height: 1.1;
      margin-bottom: 1rem;
      max-width: 660px;
    }

    .hero p { color: var(--text-muted); font-size: 1.05rem; max-width: 600px; }

    .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; margin: 1.5rem 0 1.2rem; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.95rem 1.35rem;
      border-radius: 999px;
      font-weight: 600;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn-primary {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-strong) 100%);
      color: white;
      box-shadow: 0 12px 30px rgba(31, 140, 255, 0.35);
    }
    .btn-secondary {
      background: rgba(255, 255, 255, 0.06);
      color: var(--text);
      border: 1px solid var(--border);
    }

    .hero-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      list-style: none;
      color: var(--text-muted);
      font-size: 0.95rem;
    }

    .hero-list li {
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
    }

    .hero-card {
      background: linear-gradient(160deg, rgba(255,255,255,0.12), rgba(255,255,255,0.04));
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 1.4rem;
      box-shadow: var(--shadow);
    }

    .hero-card h3 { font-size: 1.05rem; margin-bottom: 1rem; }
    .stack-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.8rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .stack-item:last-child { border-bottom: none; }
    .stack-item strong { display: block; color: white; margin-bottom: 0.2rem; }
    .stack-item span { color: var(--text-muted); font-size: 0.92rem; }
    .stack-icon {
      width: 40px;
      height: 40px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      font-weight: 700;
      color: var(--bg);
      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
      flex-shrink: 0;
    }

    section { padding: 4.2rem 0; }
    .section-heading { max-width: 700px; margin-bottom: 2rem; }
    .section-heading h2 { font-size: clamp(1.6rem, 2.6vw, 2.2rem); margin-bottom: 0.65rem; }
    .section-heading p { color: var(--text-muted); }

    .pillars-grid, .services-grid, .testimonial-grid {
      display: grid;
      gap: 1.25rem;
    }

    .pillars-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .services-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .testimonial-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }

    .card {
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 1.35rem;
      box-shadow: var(--shadow);
    }
    .card h3 { margin: 0.4rem 0 0.6rem; font-size: 1.08rem; color: white; }
    .card p, .card li { color: var(--text-muted); font-size: 0.95rem; }
    .card ul { margin-top: 0.7rem; padding-left: 1rem; }

    .stats {
      background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 2.2rem 0;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
    }

    .stat-box {
      padding: 1rem;
      border-radius: 16px;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--border);
      text-align: center;
    }
    .stat-value { font-size: 1.45rem; font-weight: 700; color: var(--primary); }
    .stat-label { color: var(--text-muted); font-size: 0.9rem; }

    .approach-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 1.5rem;
      align-items: start;
    }

    .steps { display: grid; gap: 0.9rem; }
    .step {
      display: flex;
      gap: 0.85rem;
      padding: 0.95rem;
      border-radius: 16px;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--border);
    }
    .step-number {
      width: 36px; height: 36px; border-radius: 50%;
      display: grid; place-items: center; font-weight: 700;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: var(--bg);
      flex-shrink: 0;
    }

    .contact-card {
      background: linear-gradient(135deg, rgba(62,197,255,0.16), rgba(31,140,255,0.08));
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 2rem;
      box-shadow: var(--shadow);
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 0.95fr 1.05fr;
      gap: 1.25rem;
      align-items: start;
    }

    .contact-info p { color: var(--text-muted); margin-top: 0.7rem; }
    .contact-method { margin-top: 1rem; }
    .contact-method strong { display: block; color: white; margin-bottom: 0.2rem; }

    form { display: grid; gap: 0.9rem; }
    label { font-weight: 600; color: white; font-size: 0.95rem; }
    input, select, textarea {
      width: 100%;
      padding: 0.8rem 0.9rem;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(7,17,29,0.6);
      color: white;
      font: inherit;
    }
    input:focus, select:focus, textarea:focus { outline: 2px solid rgba(62,197,255,0.3); border-color: var(--primary); }
    textarea { min-height: 110px; resize: vertical; }
    .required { color: var(--primary); }

    .form-response {
      padding: 0.8rem 0.9rem;
      border-radius: 12px;
      display: none;
      font-size: 0.95rem;
    }
    .form-response.success { display: block; background: rgba(32, 201, 151, 0.2); color: #b8f5e2; }
    .form-response.error { display: block; background: rgba(220, 53, 69, 0.2); color: #ffc7d0; }

    footer {
      padding: 2rem 0 2.5rem;
      color: var(--text-muted);
      border-top: 1px solid var(--border);
    }
    .footer-content { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }

    @media (max-width: 900px) {
      .hero-grid, .approach-grid, .contact-grid { grid-template-columns: 1fr; }
      .pillars-grid, .services-grid, .testimonial-grid, .stats-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 640px) {
      .header-inner { flex-direction: column; gap: 0.7rem; }
      .nav-links { flex-wrap: wrap; justify-content: center; }
      .hero { padding-top: 3.5rem; }
      .hero-actions { flex-direction: column; }
      .pillars-grid, .services-grid, .testimonial-grid, .stats-grid { grid-template-columns: 1fr; }
      .contact-card { padding: 1.2rem; }
      .footer-content { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="#top">Obs<span>Consulta</span></a>
      <nav class="nav-links">
        <a href="#servicos">Serviços</a>
        <a href="#pillars">Pilares</a>
        <a href="#beneficios">Abordagem</a>
        <a href="#contato">Contato</a>
      </nav>
    </div>
  </header>

  <section class="hero" id="top">
    <div class="container hero-grid">
      <div>
        <div class="eyebrow">Solution Architect • Observability • Multi-cloud</div>
        <h1>Transforme observabilidade em uma vantagem estratégica.</h1>
        <p>Eu ajudo empresas a construir arquiteturas resilientes e visibilidade operacional para aplicações distribuídas, ambientes híbridos e infraestruturas multi-cloud.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#contato">Agendar conversa</a>
          <a class="btn btn-secondary" href="#servicos">Ver serviços</a>
        </div>
        <ul class="hero-list">
          <li>Application & infrastructure</li>
          <li>Metrics • Traces • Logs</li>
          <li>Cloud-native architecture</li>
        </ul>
      </div>

      <div class="hero-card">
        <h3>Como eu ajudo</h3>
        <div class="stack-item">
          <div class="stack-icon">M</div>
          <div>
            <strong>Métricas</strong>
            <span>Estratégia de indicadores, SLOs e alertas orientados a negócio.</span>
          </div>
        </div>
        <div class="stack-item">
          <div class="stack-icon">T</div>
          <div>
            <strong>Traces</strong>
            <span>Rastreamento distribuído para reduzir MTTR e entender gargalos.</span>
          </div>
        </div>
        <div class="stack-item">
          <div class="stack-icon">L</div>
          <div>
            <strong>Logs</strong>
            <span>Centralização e correlação para investigação rápida e confiável.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="container stats-grid">
      <div class="stat-box">
        <div class="stat-value">99.9%</div>
        <div class="stat-label">alinhamento operacional</div>
      </div>
      <div class="stat-box">
        <div class="stat-value">&lt; 15m</div>
        <div class="stat-label">para detectar incidentes</div>
      </div>
      <div class="stat-box">
        <div class="stat-value">3 pilares</div>
        <div class="stat-label">metrics, traces e logs</div>
      </div>
      <div class="stat-box">
        <div class="stat-value">Multi-cloud</div>
        <div class="stat-label">arquiteturas distribuídas</div>
      </div>
    </div>
  </section>

  <section id="pillars">
    <div class="container">
      <div class="section-heading">
        <div class="eyebrow">Pilares de observabilidade</div>
        <h2>Uma base sólida para operar com confiança.</h2>
        <p>Construo soluções que conectam dados técnicos a decisões de negócio, com foco em resiliência, performance e tempo de resposta.</p>
      </div>
      <div class="pillars-grid">
        <article class="card">
          <h3>Métricas</h3>
          <p>Definição de SLI/SLO, dashboards, alertas e indicadores executivos para entender o estado real do ambiente.</p>
        </article>
        <article class="card">
          <h3>Traces</h3>
          <p>Rastreamento ponta a ponta para localizar gargalos em microsserviços, APIs e integrações distribuídas.</p>
        </article>
        <article class="card">
          <h3>Logs</h3>
          <p>Centralização, correlação e retenção inteligente para investigação rápida, auditoria e análise de incidentes.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="servicos">
    <div class="container">
      <div class="section-heading">
        <div class="eyebrow">Serviços</div>
        <h2>Estratégia, implementação e evolução contínua.</h2>
        <p>Do desenho inicial até a operação diária, eu entrego soluções práticas para equipes de tecnologia e negócios.</p>
      </div>
      <div class="services-grid">
        <article class="card">
          <h3>Arquitetura de observabilidade</h3>
          <p>Desenho de referência para aplicações modernas, com foco em performance, escalabilidade e governança.</p>
          <ul>
            <li>Mapeamento de sinais</li>
            <li>Estrutura de dados e pipelines</li>
            <li>Escolha de stack</li>
          </ul>
        </article>
        <article class="card">
          <h3>Implementação prática</h3>
          <p>Configuração de ferramentas e fluxos para monitorar aplicações, infraestruturas e integrações complexas.</p>
          <ul>
            <li>Prometheus, Grafana e OpenTelemetry</li>
            <li>Dashboards e alertas</li>
            <li>Integrações com cloud providers</li>
          </ul>
        </article>
        <article class="card">
          <h3>Consultoria e capacitação</h3>
          <p>Treinamento para times que querem operar com autonomia e maturidade observável.</p>
          <ul>
            <li>Workshops e mentoria</li>
            <li>Boas práticas operacionais</li>
            <li>Roadmaps de evolução</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section id="beneficios">
    <div class="container approach-grid">
      <div class="section-heading">
        <div class="eyebrow">Abordagem</div>
        <h2>Uma jornada clara para reduzir risco e acelerar a operação.</h2>
        <p>Minha abordagem combina visão arquitetural, implementação prática e acompanhamento contínuo para que a observabilidade gere valor real.</p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <div>
            <strong>Diagnóstico</strong>
            <p>Entendo sua arquitetura atual, limites de observabilidade e gargalos críticos.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <div>
            <strong>Desenho</strong>
            <p>Defino uma estratégia com métricas, traces, logs e cobertura para aplicações e infraestrutura.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <div>
            <strong>Execução</strong>
            <p>Implementei a solução com foco em tempo de valor, qualidade e governança.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-heading">
        <div class="eyebrow">Prova de valor</div>
        <h2>Resultados que reforçam confiança operacional.</h2>
      </div>
      <div class="testimonial-grid">
        <article class="card">
          <h3>“Redução significativa do MTTR”</h3>
          <p>Time passou a localizar falhas com rapidez e precisão após estruturar observabilidade ponta a ponta.</p>
        </article>
        <article class="card">
          <h3>“Visibilidade para ambientes complexos”</h3>
          <p>Infraestrutura distribuída passou a ser monitorada com contexto, correlação e alertas mais úteis.</p>
        </article>
        <article class="card">
          <h3>“Decisões mais rápidas”</h3>
          <p>Equipes passaram a operar com base em sinais confiáveis, e não apenas em incidentes.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="contato">
    <div class="container contact-card">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="eyebrow">Vamos conversar</div>
          <h2>Pronto para elevar a observabilidade da sua plataforma?</h2>
          <p>Preencha o formulário e vamos discutir como trazer mais clareza, resiliência e controle para sua operação.</p>
          <div class="contact-method">
            <strong>Email</strong>
            <span>renatobarufi@gmail.com</span>
          </div>
          <div class="contact-method">
            <strong>Telefone</strong>
            <span>+55 (11) 99327-7375</span>
          </div>
        </div>

        <form id="contactForm">
          <div class="form-group">
            <label for="nome">Nome completo <span class="required">*</span></label>
            <input type="text" id="nome" name="nome" required>
          </div>
          <div class="form-group">
            <label for="email">Email <span class="required">*</span></label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="empresa">Empresa <span class="required">*</span></label>
            <input type="text" id="empresa" name="empresa" required>
          </div>
          <div class="form-group">
            <label for="telefone">Telefone</label>
            <input type="tel" id="telefone" name="telefone">
          </div>
          <div class="form-group">
            <label for="servico">Serviço de interesse <span class="required">*</span></label>
            <select id="servico" name="servico" required>
              <option value="">Selecione um serviço</option>
              <option value="arquitetura">Arquitetura de observabilidade</option>
              <option value="implementacao">Implementação prática</option>
              <option value="consultoria">Consultoria e capacitação</option>
              <option value="outro">Outro</option>
            </select>
          </div>
          <div class="form-group">
            <label for="descricao">Descreva sua necessidade</label>
            <textarea id="descricao" name="descricao" placeholder="Conte um pouco sobre sua aplicação, infraestrutura e desafios atuais..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; border: none; cursor: pointer;">Enviar cadastro</button>
          <div id="formResponse" class="form-response"></div>
        </form>
      </div>
    </div>
  </section>

  <footer>
    <div class="container footer-content">
      <div>
        <strong>ObsConsulta</strong>
        <p>Architecture & Observability for distributed systems.</p>
      </div>
      <small>© 2026 ObsConsulta. Todos os direitos reservados.</small>
    </div>
  </footer>

  <script>
    const form = document.getElementById('contactForm');
    const responseDiv = document.getElementById('formResponse');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = {
        nome: document.getElementById('nome').value,
        email: document.getElementById('email').value,
        empresa: document.getElementById('empresa').value,
        telefone: document.getElementById('telefone').value,
        servico: document.getElementById('servico').value,
        descricao: document.getElementById('descricao').value
      };

      try {
        const response = await fetch('/api/leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });

        const data = await response.json();

        if (response.ok) {
          responseDiv.textContent = '✓ ' + data.message;
          responseDiv.classList.remove('error');
          responseDiv.classList.add('success');
          form.reset();
          setTimeout(() => responseDiv.classList.remove('success'), 5000);
        } else {
          responseDiv.textContent = '✗ ' + data.error;
          responseDiv.classList.remove('success');
          responseDiv.classList.add('error');
        }
      } catch (error) {
        responseDiv.textContent = '✗ Erro ao enviar. Tente novamente.';
        responseDiv.classList.remove('success');
        responseDiv.classList.add('error');
        console.error(error);
      }
    });

    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    });
  </script>
</body>
</html>
