# Porta do servidor
PORT=3000

# Ambiente
NODE_ENV=development

# Email para contato (para integração futura)
CONTACT_EMAIL=contato@obsconsulta.com.br

# Dados de contato
CONTACT_PHONE=+55 (11) 9 9999-9999
CONTACT_HOURS=Seg-Sex, 9h às 18h (Brasília)

# Configurações de Log
LOG_LEVEL=info

# CORS (para API)
CORS_ORIGIN=http://localhost:3000

# Segurança
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Email (para integração com NodeMailer ou similar)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# SendGrid (alternativa para envio de email)
SENDGRID_API_KEY=

# Banco de dados (para migração futura)
DB_PATH=./leads.json

# API Key (para proteger /api/leads em produção)
API_KEY=
